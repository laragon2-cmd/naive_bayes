training_emails[[1]]
#install and load package for easy text analysis
install.packages("stringr")
library(stringr)

#Change words within SpamString to look for different keywords
#Change the number of loops depending on number of keywords
SpamStrings <- c("This", "that", "me", "you")
fitsmatrix <- NULL
for (k in 1:4){
  fitsvector <- numeric()
  for(i in 1:length(training_emails)){  
    fits <- sum(str_count(training_emails[[i]], SpamStrings[k]))
    if (fits == 0){
      fits = 0
    } else {
      fits = 1
    }
    fitsvector <- c(fitsvector, fits)
  }
  fitsmatrix <- cbind(fitsmatrix, fitsvector)
}
#fitsmatrix will consist of 0 and 1s depending on whether the keyword is found at least once or not.

